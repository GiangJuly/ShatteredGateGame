  finalBossPrefab: {fileID: 4614854346512350602, guid: 4b9c278c82df2cd4db585bb3372ad5ce, type: 3}
  finalBossName: Zero
  finalBossIcon: {fileID: 21300000, guid: 3510a23e44c1610489be69f7a7056fcb, type: 3}
  openingStoryText: "The Sundering tore the world into a thousand drifting fragments.
    Graham woke alone in the ruins of what was once his home, with no memory of how
    the sky came to break. All that remains is a shard of the Gate itself \u2014
    warm in his palm, pulling him toward every portal he finds. Somewhere beyond
    them lies the truth of what happened here... and perhaps, a way back. He steps
    through the first Gate alone."
  finalBossIntroText: "At the heart of the deepest fragment stands Zero \u2014 not
    a monster, but a wound given form: the last splinter of whatever broke the world
    apart. To close the Gates, Graham must face it."
  victoryEpilogueText: "The last Gate closes behind you. The fragments do not heal
    \u2014 but they stop falling. For now, that is enough."
